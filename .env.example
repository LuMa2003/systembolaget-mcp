# ──────────────────────────────────────────────────────────────────────────
# sb-stack environment variables.
# Copy to `.env` and edit for your setup. All variables are prefixed SB_.
# Authoritative list: docs/06_module_layout.md §Settings + docs/07_deployment.md.
# ──────────────────────────────────────────────────────────────────────────

# ── Storage ───────────────────────────────────────────────────────────────
SB_DATA_DIR=/data

# ── Home stores (siteIds; comma-separated) ────────────────────────────────
# Defaults are the project owner's home stores; override for your own.
SB_STORE_SUBSET=1701,1702,1716,1718
SB_MAIN_STORE=1701

# ── Systembolaget API ─────────────────────────────────────────────────────
# Ecommerce APIM key (covers /sb-api-ecommerce/v1/*). Leave blank to
# auto-extract from the public frontend JS at startup.
SB_API_KEY=
SB_API_KEY_CACHE_TTL_DAYS=7
# Mobile APIM key (covers /sb-api-mobile/v1/* — stock + taxonomy). Not in
# the web frontend; the default below came from the open-source project
# C4illin/systembolaget-data and is still accepted server-side as of
# 2026-04-20. If /sb-api-mobile/* starts 401'ing, capture a fresh key
# from the Systembolaget mobile app's network traffic and set it here —
# the orchestrator fires a one-shot ntfy alert when the default is revoked.
SB_API_KEY_MOBILE=cfc702aed3094c86b92d6d4ff7a54c84
SB_API_BASE_URL=https://api-extern.systembolaget.se
SB_APP_BASE_URL=https://www.systembolaget.se

# ── Embedding service ─────────────────────────────────────────────────────
SB_EMBED_URL=http://localhost:9000/v1/embeddings
SB_EMBED_MODEL=Qwen/Qwen3-Embedding-4B
SB_EMBED_DIM=2560
SB_EMBED_DEVICE=cuda:0
SB_EMBED_PORT=9000
SB_EMBED_MAX_BATCH=2048
SB_EMBED_GPU_BATCH_SIZE=32
SB_EMBED_CLIENT_BATCH_SIZE=128

# ── MCP server ────────────────────────────────────────────────────────────
SB_MCP_PORT=8000
SB_MCP_TRANSPORT=http
# Required when transport=http. Generate a strong random value.
SB_MCP_TOKEN=

# ── Sync scheduling ───────────────────────────────────────────────────────
SB_SYNC_CRON=0 4 * * *
SB_SYNC_TIMEZONE=Europe/Stockholm
SB_FIRST_RUN_ON_BOOTSTRAP=true
SB_SYNC_CONCURRENCY=5

# ── Retention ─────────────────────────────────────────────────────────────
SB_BACKUP_RETENTION_DAYS=7
SB_RAW_RETENTION_DAYS=365

# ── Phase timeouts (minutes) ──────────────────────────────────────────────
SB_PHASE_FETCH_TIMEOUT_MINUTES=20
SB_PHASE_PERSIST_TIMEOUT_MINUTES=5
SB_PHASE_DETAILS_TIMEOUT_MINUTES=60
SB_PHASE_EMBED_TIMEOUT_MINUTES=60
SB_PHASE_INDEX_TIMEOUT_MINUTES=2
SB_PHASE_FINALIZE_TIMEOUT_MINUTES=2

# ── Ntfy notifier (optional; leave SB_NTFY_URL blank to disable) ──────────
SB_NTFY_URL=
SB_NTFY_TOKEN=
SB_NTFY_COOLDOWN_HOURS=6
SB_NTFY_MIN_PRIORITY=3

# ── Logging ───────────────────────────────────────────────────────────────
SB_LOG_LEVEL=info
SB_LOG_FORMAT=json
SB_LOG_TO_FILE=true
SB_LOG_TO_STDOUT=true
